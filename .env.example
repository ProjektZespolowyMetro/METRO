# Skopiuj do .env w katalogu głównym projektu i dostosuj przed uruchomieniem na serwerze.
#   cp env.example .env

# Wymagane — wygeneruj: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# Produkcja (np. AWS EC2)
DJANGO_DEBUG=False
# IP lub domena serwera (bez http://); wiele wartości po przecinku
DJANGO_ALLOWED_HOSTS=3.73.73.77,127.0.0.1
# Przy HTTPS — wymagane do logowania w /admin/
# DJANGO_CSRF_TRUSTED_ORIGINS=https://twoja-domena.pl

# Development (lokalnie)
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
